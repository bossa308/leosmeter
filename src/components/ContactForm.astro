---
const key = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const hasKey = key && key.trim().length > 0;
---

{hasKey ? (
  <form
    action="https://api.web3forms.com/submit"
    method="POST"
    class="space-y-5"
  >
    <input type="hidden" name="access_key" value={key} />
    <input type="hidden" name="subject" value="ติดต่อสอบถาม — LEOS METER" />
    <input type="hidden" name="from_name" value="LEOS METER Website" />

    <!-- Honeypot -->
    <input
      type="checkbox"
      name="botcheck"
      class="hidden"
      style="display:none"
      tabindex="-1"
      autocomplete="off"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">
          ชื่อ – นามสกุล <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand focus:border-brand outline-none transition"
          placeholder="สมชาย ใจดี"
        />
      </div>
      <div>
        <label for="company" class="block text-sm font-semibold text-gray-700 mb-1">
          บริษัท / หน่วยงาน
        </label>
        <input
          type="text"
          id="company"
          name="company"
          autocomplete="organization"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand focus:border-brand outline-none transition"
          placeholder="บริษัท ABC จำกัด"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
          อีเมล <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand focus:border-brand outline-none transition"
          placeholder="email@company.com"
        />
      </div>
      <div>
        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">
          เบอร์โทรศัพท์
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          autocomplete="tel"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand focus:border-brand outline-none transition"
          placeholder="08x-xxx-xxxx"
        />
      </div>
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">
        ข้อความ <span class="text-red-500">*</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="5"
        class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand focus:border-brand outline-none transition resize-y"
        placeholder="กรุณาระบุสินค้าที่สนใจ จำนวน หรือข้อมูลเพิ่มเติม..."
      ></textarea>
    </div>

    <button
      type="submit"
      class="w-full btn-primary py-3 text-base"
    >
      ส่งข้อความ
    </button>

    <p class="text-xs text-gray-400 text-center">
      ข้อมูลของท่านจะถูกรักษาเป็นความลับ เราจะติดต่อกลับภายใน 1 วันทำการ
    </p>
  </form>
) : (
  <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center">
    <p class="text-amber-800 font-semibold mb-1">ฟอร์มยังไม่พร้อมใช้งาน</p>
    <p class="text-sm text-amber-700">
      กรุณาตั้งค่า <code class="font-mono bg-amber-100 px-1 rounded">PUBLIC_WEB3FORMS_KEY</code> ใน .env เพื่อเปิดใช้งานฟอร์ม
    </p>
    <p class="text-sm text-amber-700 mt-3">
      ในระหว่างนี้ กรุณาติดต่อเราทางโทรศัพท์ หรือ LINE: @leosmeter
    </p>
  </div>
)}
