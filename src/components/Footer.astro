---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 text-white font-bold text-lg mb-3">
          <Icon name="lucide:zap" class="w-5 h-5 text-blue-400" aria-hidden="true" />
          <span>LEOS METER</span>
        </div>
        <p class="text-sm leading-relaxed text-gray-400">
          ตัวแทนจำหน่ายอุปกรณ์วัดแสดงผลอุตสาหกรรม<br />
          เพาเวอร์มิเตอร์ · จอแสดงผล · นาฬิกา NTP<br />
          Haiwell PLC/HMI
        </p>
        <p class="text-xs text-gray-500 mt-3">บริษัท SME INTER จำกัด</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">สินค้า</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/category/power-meter" class="hover:text-white transition-colors">เพาเวอร์มิเตอร์</a></li>
          <li><a href="/category/jumbo-display" class="hover:text-white transition-colors">จอแสดงผลขนาดใหญ่</a></li>
          <li><a href="/category/ntp-clock" class="hover:text-white transition-colors">นาฬิกา NTP</a></li>
          <li><a href="/category/haiwell" class="hover:text-white transition-colors">Haiwell PLC/HMI</a></li>
          <li><a href="/products" class="hover:text-white transition-colors">สินค้าทั้งหมด</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">ติดต่อเรา</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <Icon name="lucide:phone" class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" aria-hidden="true" />
            <span>02-xxx-xxxx (ตัวอย่าง)</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:message-circle" class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" aria-hidden="true" />
            <span>LINE: @leosmeter</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:mail" class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" aria-hidden="true" />
            <span>info@[placeholder]</span>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" aria-hidden="true" />
            <span>กรุงเทพมหานคร, ประเทศไทย</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {year} LEOS METER | SME INTER. สงวนลิขสิทธิ์</p>
      <div class="flex items-center gap-4">
        <a href="/about" class="hover:text-gray-300 transition-colors">เกี่ยวกับเรา</a>
        <a href="/contact" class="hover:text-gray-300 transition-colors">ติดต่อ</a>
      </div>
    </div>
  </div>
</footer>
