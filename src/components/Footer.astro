---
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="bg-navy text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 text-white font-extrabold text-lg mb-3">
          <Icon name="lucide:zap" class="w-5 h-5 text-cyan shrink-0" aria-hidden="true" />
          <span>LEOS METER</span>
        </div>
        <p class="text-sm leading-relaxed text-gray-400 mb-4">
          ผลิตและจัดจำหน่ายอุปกรณ์วัดแสดงผลสำหรับงานอุตสาหกรรม<br />
          เพาเวอร์มิเตอร์ · จอแสดงผล · นาฬิกา NTP · Haiwell PLC/HMI
        </p>
        <p class="text-xs text-gray-500 mb-4">{site.company}</p>
        <div class="flex items-center gap-2">
          <a
            href={site.line}
            target="_blank"
            rel="noopener"
            class="bg-green-600 text-white text-xs font-bold px-3 py-1.5 rounded hover:bg-green-500 transition-colors"
          >
            LINE {site.lineId}
          </a>
          <a
            href={site.youtube}
            target="_blank"
            rel="noopener"
            class="bg-red-700 text-white text-xs font-bold px-3 py-1.5 rounded hover:bg-red-600 transition-colors"
          >
            YouTube
          </a>
          <a
            href={site.facebook}
            target="_blank"
            rel="noopener"
            class="bg-blue-700 text-white text-xs font-bold px-3 py-1.5 rounded hover:bg-blue-600 transition-colors"
          >
            Facebook
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">สินค้า</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/category/power-meter" class="hover:text-white transition-colors">เพาเวอร์มิเตอร์</a></li>
          <li><a href="/category/multifunction-meter" class="hover:text-white transition-colors">มัลติฟังก์ชันมิเตอร์</a></li>
          <li><a href="/category/jumbo-display" class="hover:text-white transition-colors">จอแสดงผลขนาดใหญ่</a></li>
          <li><a href="/category/ntp-clock" class="hover:text-white transition-colors">นาฬิกา NTP</a></li>
          <li><a href="/category/haiwell-plc" class="hover:text-white transition-colors">Haiwell PLC</a></li>
          <li><a href="/category/haiwell-hmi" class="hover:text-white transition-colors">Haiwell HMI</a></li>
          <li><a href="/products" class="text-cyan hover:underline transition-colors mt-1 block">ดูสินค้าทั้งหมด →</a></li>
        </ul>
      </div>

      <!-- Help -->
      <div>
        <h3 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Support</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/downloads" class="hover:text-white transition-colors">Download Center</a></li>
          <li><a href="/tutorial" class="hover:text-white transition-colors">Tutorial & บทความ</a></li>
          <li><a href="/tutorial#firmware" class="hover:text-white transition-colors">Firmware Update</a></li>
          <li><a href="/tutorial#qa" class="hover:text-white transition-colors">FAQ คำถามที่พบบ่อย</a></li>
          <li><a href="/solutions" class="hover:text-white transition-colors">Industrial Solutions</a></li>
          <li><a href="/product-selector" class="hover:text-white transition-colors">Product Selector</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">เกี่ยวกับเรา</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">ติดต่อเรา</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">ติดต่อเรา</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 mt-0.5 text-cyan shrink-0" aria-hidden="true" />
            <span class="text-gray-400 leading-relaxed">{site.address}</span>
          </li>
          {site.phone.map((p) => (
            <li class="flex items-center gap-2">
              <Icon name="lucide:phone" class="w-4 h-4 text-cyan shrink-0" aria-hidden="true" />
              <a href={`tel:${p.replace(/-/g, '')}`} class="hover:text-white transition-colors">{p}</a>
            </li>
          ))}
          <li class="flex items-center gap-2">
            <Icon name="lucide:mail" class="w-4 h-4 text-cyan shrink-0" aria-hidden="true" />
            <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="lucide:clock" class="w-4 h-4 mt-0.5 text-cyan shrink-0" aria-hidden="true" />
            <span class="text-gray-400">{site.hours}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500">
      <p>© {year} LEOS METER | {site.company}. สงวนลิขสิทธิ์</p>
      <p>Made in Thailand 🇹🇭</p>
    </div>
  </div>
</footer>
