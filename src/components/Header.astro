---
import { Icon } from 'astro-icon/components';
import TopBar from './TopBar.astro';
import MegaMenu from './MegaMenu.astro';
import { site } from '../data/site';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/solutions',  label: 'Solutions' },
  { href: '/downloads',  label: 'Downloads' },
  { href: '/tutorial',   label: 'Support' },
  { href: '/about',      label: 'About' },
  { href: '/contact',    label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<TopBar />
<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center h-16 gap-2">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-navy font-extrabold text-lg shrink-0 mr-3 hover:text-brand transition-colors">
        <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center">
          <Icon name="lucide:zap" class="w-4 h-4 text-white" aria-hidden="true" />
        </div>
        <span class="tracking-tight">LEOS METER</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-0.5 flex-1">
        <MegaMenu />
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`px-3.5 py-2 rounded-lg text-sm font-semibold transition-colors ${
                isActive(href)
                  ? 'bg-brand/10 text-brand'
                  : 'text-gray-700 hover:text-brand hover:bg-gray-50'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-2 ml-auto shrink-0">
        <a
          href={site.line}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 bg-green-500 text-white font-bold text-sm px-4 py-2 rounded-lg hover:bg-green-400 transition-colors"
        >
          LINE OA
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-1.5 bg-brand text-white font-bold text-sm px-4 py-2 rounded-lg hover:bg-brand/90 transition-colors"
        >
          <Icon name="lucide:send" class="w-4 h-4" aria-hidden="true" />
          ติดต่อสอบถาม
        </a>
      </div>

      <!-- Mobile hamburger — zero JS -->
      <details class="md:hidden relative ml-auto">
        <summary class="list-none cursor-pointer p-2 rounded-lg text-gray-600 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-brand">
          <Icon name="lucide:menu" class="w-6 h-6" aria-hidden="true" />
          <span class="sr-only">เปิดเมนู</span>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-72 bg-white border border-gray-200 rounded-xl shadow-xl py-2 max-h-[80vh] overflow-y-auto">
          <ul>
            <MegaMenu />
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class={`flex items-center px-4 py-3 text-sm font-semibold transition-colors ${
                    isActive(href)
                      ? 'text-brand bg-brand/5'
                      : 'text-gray-700 hover:bg-gray-50 hover:text-brand'
                  }`}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
          <div class="border-t border-gray-100 mt-2 pt-3 pb-2 px-4 flex flex-col gap-2">
            <a
              href={site.line}
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center gap-2 bg-green-500 text-white font-bold text-sm py-2.5 rounded-lg"
            >
              LINE OA · {site.lineId}
            </a>
            <a
              href="/contact"
              class="flex items-center justify-center gap-2 bg-brand text-white font-bold text-sm py-2.5 rounded-lg"
            >
              <Icon name="lucide:send" class="w-4 h-4" aria-hidden="true" />
              ติดต่อสอบถาม
            </a>
            <a
              href={`tel:${site.phone[0].replace(/-/g, '')}`}
              class="flex items-center justify-center gap-2 border border-gray-200 text-gray-700 font-semibold text-sm py-2.5 rounded-lg"
            >
              <Icon name="lucide:phone" class="w-4 h-4" aria-hidden="true" />
              {site.phone[0]}
            </a>
          </div>
        </div>
      </details>
    </div>
  </nav>
</header>
