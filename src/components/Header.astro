---
import { Icon } from 'astro-icon/components';

const navLinks = [
  { href: '/', label: 'หน้าแรก' },
  { href: '/products', label: 'สินค้า' },
  { href: '/about', label: 'เกี่ยวกับเรา' },
  { href: '/contact', label: 'ติดต่อ' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-brand font-bold text-lg shrink-0">
        <Icon name="lucide:zap" class="w-6 h-6" aria-hidden="true" />
        <span>LEOS METER</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPath === href
                  ? 'bg-brand/10 text-brand'
                  : 'text-gray-600 hover:text-brand hover:bg-gray-50'
              }`}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <a href="/contact" class="hidden md:inline-flex items-center gap-2 btn-primary text-sm py-2 px-4">
        <Icon name="lucide:phone" class="w-4 h-4" aria-hidden="true" />
        ติดต่อสอบถาม
      </a>

      <!-- Mobile menu via <details> — zero JS -->
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer p-2 rounded-lg text-gray-600 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-brand">
          <Icon name="lucide:menu" class="w-6 h-6" aria-hidden="true" />
          <span class="sr-only">เปิดเมนู</span>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-56 bg-white border border-gray-200 rounded-xl shadow-lg py-2">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class={`block px-4 py-3 text-sm font-medium transition-colors ${
                currentPath === href
                  ? 'text-brand bg-brand/5'
                  : 'text-gray-700 hover:bg-gray-50 hover:text-brand'
              }`}
            >
              {label}
            </a>
          ))}
          <div class="border-t border-gray-100 mt-2 pt-2 px-4 pb-1">
            <a href="/contact" class="btn-primary text-sm py-2 w-full text-center block">
              ติดต่อสอบถาม
            </a>
          </div>
        </div>
      </details>
    </div>
  </nav>
</header>
