---
import { Icon } from 'astro-icon/components';
import { categoryGroups } from '../data/categories';
---

<!-- Desktop mega menu (CSS group-hover, 0 KB JS) -->
<li class="group relative hidden md:block">
  <button
    class="flex items-center gap-1 px-4 py-2 text-sm font-semibold text-gray-700 hover:text-brand rounded-lg hover:bg-gray-50 transition-colors"
    aria-haspopup="true"
  >
    สินค้า
    <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" aria-hidden="true" />
  </button>

  <!-- Dropdown panel -->
  <div
    class="pointer-events-none group-hover:pointer-events-auto opacity-0 group-hover:opacity-100
           absolute left-1/2 -translate-x-1/2 top-full mt-0 w-[860px]
           bg-white shadow-2xl border-t-2 border-brand rounded-b-xl
           transition-all duration-200 origin-top scale-y-95 group-hover:scale-y-100 z-50"
  >
    <div class="grid grid-cols-3 gap-x-8 gap-y-1 p-7">
      {categoryGroups.map((group) => (
        <div class="mb-4">
          <p class="flex items-center gap-1.5 text-xs font-bold text-gray-400 uppercase tracking-wider mb-2.5">
            <Icon name={group.icon} class="w-3.5 h-3.5" aria-hidden="true" />
            {group.name}
          </p>
          <ul class="space-y-1">
            {group.categories.map((cat) => (
              <li>
                <a
                  href={`/category/${cat.slug}`}
                  class="block text-sm text-gray-700 hover:text-brand hover:bg-brand/5 px-2 py-1 rounded-md transition-colors"
                >
                  {cat.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="border-t border-gray-100 px-7 py-3 bg-gray-50 rounded-b-xl flex items-center justify-between">
      <span class="text-xs text-gray-400">LEOS METER — สินค้ากว่า 100 รายการ</span>
      <a href="/products" class="text-xs font-semibold text-brand hover:underline">ดูสินค้าทั้งหมด →</a>
    </div>
  </div>
</li>

<!-- Mobile product submenu (inside the <details> mobile nav) -->
<li class="md:hidden">
  <details class="group/prod">
    <summary class="flex items-center justify-between w-full px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer list-none">
      สินค้า
      <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200 group-open/prod:rotate-180" aria-hidden="true" />
    </summary>
    <div class="bg-gray-50 border-t border-gray-100 px-4 py-3 space-y-4">
      {categoryGroups.map((group) => (
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">{group.name}</p>
          <ul class="grid grid-cols-2 gap-x-2 gap-y-1">
            {group.categories.map((cat) => (
              <li>
                <a href={`/category/${cat.slug}`} class="text-sm text-gray-700 hover:text-brand">
                  {cat.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <a href="/products" class="block text-sm font-semibold text-brand pt-2 border-t border-gray-200">
        ดูสินค้าทั้งหมด →
      </a>
    </div>
  </details>
</li>
