---
import { Icon } from 'astro-icon/components';
import { categoryGroups } from '../data/categories';
import { getProductsByCategory } from '../data/products';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/products/*.{svg,png,jpg,webp}',
  { eager: true }
);

// Build the menu tree.  Each group's categories are annotated with the
// product list and per-subcategory counts so we can render a hybrid panel
// (subcategory list + thumbnails) in the third column.
const tree = categoryGroups
  .map((group, gIdx) => ({
    gIdx,
    group,
    categories: group.categories.map((cat) => {
      const products = getProductsByCategory(cat.slug);
      const subCounts: Record<string, number> = {};
      products.forEach((p) => {
        if (p.subcategory) subCounts[p.subcategory] = (subCounts[p.subcategory] ?? 0) + 1;
      });
      return { cat, products, subCounts };
    }),
  }))
  // Hide groups whose every category has zero products yet, to avoid an empty
  // third column. Tweak this if you want all groups visible regardless.
  .filter((g) => g.categories.some((c) => c.products.length > 0));

const defaultGroupIdx = tree[0]?.gIdx ?? 0;
const defaultCatSlug =
  tree[0]?.categories.find((c) => c.products.length > 0)?.cat.slug ??
  tree[0]?.categories[0]?.cat.slug ??
  '';
---

<!-- ============== DESKTOP MEGA MENU (3-level cascading) ============== -->
<li class="group relative hidden md:block">
  <button
    class="flex items-center gap-1 px-4 py-2 text-sm font-semibold text-gray-700 hover:text-brand rounded-lg hover:bg-gray-50 transition-colors"
    aria-haspopup="true"
    aria-expanded="false"
  >
    สินค้า
    <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" aria-hidden="true" />
  </button>

  <!-- Panel -->
  <div
    id="mega-panel"
    data-active-group={String(defaultGroupIdx)}
    data-active-cat={defaultCatSlug}
    class="pointer-events-none group-hover:pointer-events-auto opacity-0 group-hover:opacity-100
           absolute left-1/2 -translate-x-1/2 top-full w-[1040px] max-w-[95vw]
           bg-white shadow-2xl border-t-2 border-brand rounded-b-xl
           transition-all duration-200 origin-top scale-y-95 group-hover:scale-y-100 z-50
           overflow-hidden"
  >
    <div class="grid grid-cols-[240px_260px_1fr] min-h-[420px]">

      <!-- ===== Column 1: GROUPS ===== -->
      <div class="bg-gray-50 border-r border-gray-200 py-3">
        <p class="px-5 mb-2 text-[10px] font-bold text-gray-400 uppercase tracking-wider">หมวดหลัก</p>
        <ul>
          {tree.map(({ gIdx, group, categories }) => {
            const productCount = categories.reduce((n, c) => n + c.products.length, 0);
            const firstCat = categories.find((c) => c.products.length > 0)?.cat.slug ?? categories[0]?.cat.slug ?? '';
            return (
              <li>
                <button
                  type="button"
                  class="mega-group-btn w-full flex items-center gap-2.5 px-5 py-2.5 text-left text-sm font-semibold text-gray-700 hover:text-brand hover:bg-white transition-colors"
                  data-group-idx={gIdx}
                  data-first-cat={firstCat}
                >
                  <Icon name={group.icon} class="w-4 h-4 text-gray-400 mega-icon" aria-hidden="true" />
                  <span class="flex-1 min-w-0 leading-tight">{group.name}</span>
                  <span class="text-xs text-gray-400 font-normal">{productCount}</span>
                  <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-gray-300" aria-hidden="true" />
                </button>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- ===== Column 2: CATEGORIES (one panel per group) ===== -->
      <div class="bg-white border-r border-gray-200 py-3 relative">
        {tree.map(({ gIdx, categories }) => (
          <div class="mega-cat-panel hidden absolute inset-0 py-3 overflow-y-auto" data-group-idx={gIdx}>
            <p class="px-5 mb-2 text-[10px] font-bold text-gray-400 uppercase tracking-wider">หมวดย่อย</p>
            <ul>
              {categories.map(({ cat, products }) => (
                <li>
                  <a
                    href={`/category/${cat.slug}`}
                    class="mega-cat-btn group/cat w-full flex items-center gap-2 px-5 py-2 text-sm text-gray-700 hover:text-brand hover:bg-brand/5 transition-colors"
                    data-cat-slug={cat.slug}
                  >
                    <span class="flex-1 min-w-0 leading-tight">{cat.name}</span>
                    {products.length > 0 ? (
                      <span class="text-xs text-gray-400 font-normal group-hover/cat:text-brand">{products.length}</span>
                    ) : (
                      <span class="text-[10px] text-gray-300 font-normal italic">เร็วๆ นี้</span>
                    )}
                    <Icon name="lucide:chevron-right" class="w-3.5 h-3.5 text-gray-300 group-hover/cat:text-brand" aria-hidden="true" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- ===== Column 3: Pure Subcategory List (with product-list fallback) ===== -->
      <div class="bg-white relative overflow-y-auto">
        {tree.flatMap(({ categories }) =>
          categories.map(({ cat, products, subCounts }) => {
            if (products.length === 0) return null;
            const subs = cat.subcategories ?? [];
            return (
              <div class="mega-product-panel hidden absolute inset-0 p-5 flex flex-col gap-4" data-cat-slug={cat.slug}>
                <!-- Header -->
                <div class="flex items-center justify-between gap-2">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">{cat.name}</p>
                  <a href={`/category/${cat.slug}`} class="text-xs font-semibold text-brand hover:underline whitespace-nowrap">
                    ดูทั้งหมด {products.length} รายการ →
                  </a>
                </div>

                {subs.length > 0 ? (
                  <!-- Category HAS subcategories — show subcategory grid -->
                  <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">หมวดย่อย</p>
                    <ul class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                      {subs.map((s) => {
                        const count = subCounts[s.slug] ?? 0;
                        return (
                          <li>
                            <a
                              href={`/products?category=${cat.slug}&subcategory=${s.slug}`}
                              class={`group/s flex items-center justify-between gap-2 px-2 py-1.5 rounded-md text-sm transition-colors ${
                                count > 0 ? 'text-gray-700 hover:text-brand hover:bg-brand/5' : 'text-gray-300 pointer-events-none'
                              }`}
                            >
                              <span class="flex-1 min-w-0 leading-tight">{s.name}</span>
                              {count > 0 ? (
                                <span class="text-[10px] text-gray-400 group-hover/s:text-brand">{count}</span>
                              ) : (
                                <span class="text-[10px] italic">เร็วๆ นี้</span>
                              )}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ) : (
                  <!-- Category has NO subcategories — fall back to a flat product list -->
                  <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">สินค้าในหมวดนี้</p>
                    <ul class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                      {products.map((p) => (
                        <li>
                          <a
                            href={`/products/${p.slug}`}
                            class="group/p flex items-center justify-between gap-2 px-2 py-1.5 rounded-md text-sm text-gray-700 hover:text-brand hover:bg-brand/5 transition-colors"
                          >
                            <span class="flex-1 min-w-0 leading-tight">{p.name}</span>
                            {p.model && (
                              <span class="text-[10px] font-mono text-gray-400 group-hover/p:text-brand truncate">{p.model}</span>
                            )}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            );
          })
        )}

        <!-- Empty-state panel: shown when active category has no products -->
        <div id="mega-product-empty" class="hidden absolute inset-0 p-5 flex items-center justify-center text-center">
          <div>
            <Icon name="lucide:package-search" class="w-10 h-10 text-gray-200 mx-auto mb-2" aria-hidden="true" />
            <p class="text-sm text-gray-500 font-semibold mb-1">รุ่นในหมวดนี้กำลังจัดเตรียม</p>
            <p class="text-xs text-gray-400">ติดต่อทีมขายเพื่อสอบถามรุ่นที่เปิดรับสั่งทำ</p>
            <a href="/contact" class="mt-3 inline-block text-xs font-semibold text-brand hover:underline">ติดต่อสอบถาม →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="border-t border-gray-100 px-5 py-3 bg-gray-50 flex items-center justify-between">
      <span class="text-xs text-gray-400">LEOS METER · Haiwell · Accessories</span>
      <a href="/products" class="text-xs font-semibold text-brand hover:underline">ดูสินค้าทั้งหมด →</a>
    </div>
  </div>
</li>

<!-- ============== MOBILE PRODUCT SUBMENU ============== -->
<li class="md:hidden">
  <details class="group/prod">
    <summary class="flex items-center justify-between w-full px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 cursor-pointer list-none">
      สินค้า
      <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200 group-open/prod:rotate-180" aria-hidden="true" />
    </summary>
    <div class="bg-gray-50 border-t border-gray-100 px-4 py-3 space-y-3">
      {tree.map(({ group, categories }) => (
        <details class="group/g">
          <summary class="flex items-center justify-between gap-2 px-2 py-1.5 cursor-pointer list-none text-xs font-bold text-gray-500 uppercase tracking-wider">
            <span class="flex items-center gap-1.5">
              <Icon name={group.icon} class="w-3 h-3" aria-hidden="true" />
              {group.name}
            </span>
            <Icon name="lucide:chevron-down" class="w-3.5 h-3.5 transition-transform group-open/g:rotate-180" aria-hidden="true" />
          </summary>
          <ul class="grid grid-cols-1 gap-y-0.5 mt-1 pl-1">
            {categories.map(({ cat, products }) => (
              <li>
                <a href={`/category/${cat.slug}`} class="flex items-center justify-between gap-2 py-1.5 px-2 text-sm text-gray-700 hover:text-brand">
                  <span>{cat.name}</span>
                  {products.length > 0 && <span class="text-xs text-gray-400">{products.length}</span>}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
      <a href="/products" class="block text-sm font-semibold text-brand pt-2 border-t border-gray-200">
        ดูสินค้าทั้งหมด →
      </a>
    </div>
  </details>
</li>

<style>
  /* Show only the col2 panel matching the active group */
  #mega-panel .mega-cat-panel { display: none; }
  #mega-panel[data-active-group="0"]  .mega-cat-panel[data-group-idx="0"]  { display: block; }
  #mega-panel[data-active-group="1"]  .mega-cat-panel[data-group-idx="1"]  { display: block; }
  #mega-panel[data-active-group="2"]  .mega-cat-panel[data-group-idx="2"]  { display: block; }
  #mega-panel[data-active-group="3"]  .mega-cat-panel[data-group-idx="3"]  { display: block; }
  #mega-panel[data-active-group="4"]  .mega-cat-panel[data-group-idx="4"]  { display: block; }
  #mega-panel[data-active-group="5"]  .mega-cat-panel[data-group-idx="5"]  { display: block; }
  #mega-panel[data-active-group="6"]  .mega-cat-panel[data-group-idx="6"]  { display: block; }
  #mega-panel[data-active-group="7"]  .mega-cat-panel[data-group-idx="7"]  { display: block; }

  /* Active group highlight in col1 */
  #mega-panel[data-active-group="0"]  .mega-group-btn[data-group-idx="0"],
  #mega-panel[data-active-group="1"]  .mega-group-btn[data-group-idx="1"],
  #mega-panel[data-active-group="2"]  .mega-group-btn[data-group-idx="2"],
  #mega-panel[data-active-group="3"]  .mega-group-btn[data-group-idx="3"],
  #mega-panel[data-active-group="4"]  .mega-group-btn[data-group-idx="4"],
  #mega-panel[data-active-group="5"]  .mega-group-btn[data-group-idx="5"],
  #mega-panel[data-active-group="6"]  .mega-group-btn[data-group-idx="6"],
  #mega-panel[data-active-group="7"]  .mega-group-btn[data-group-idx="7"] {
    background-color: white;
    color: var(--brand, #0B3D91);
  }
  #mega-panel .mega-group-btn[data-group-idx]:hover .mega-icon,
  #mega-panel[data-active-group="0"] .mega-group-btn[data-group-idx="0"] .mega-icon,
  #mega-panel[data-active-group="1"] .mega-group-btn[data-group-idx="1"] .mega-icon,
  #mega-panel[data-active-group="2"] .mega-group-btn[data-group-idx="2"] .mega-icon,
  #mega-panel[data-active-group="3"] .mega-group-btn[data-group-idx="3"] .mega-icon,
  #mega-panel[data-active-group="4"] .mega-group-btn[data-group-idx="4"] .mega-icon,
  #mega-panel[data-active-group="5"] .mega-group-btn[data-group-idx="5"] .mega-icon,
  #mega-panel[data-active-group="6"] .mega-group-btn[data-group-idx="6"] .mega-icon,
  #mega-panel[data-active-group="7"] .mega-group-btn[data-group-idx="7"] .mega-icon {
    color: var(--brand, #0B3D91);
  }

  /* Col 3 product panels are hidden by default via Tailwind's `.hidden`
     class on the markup. JS toggles that class on hover/focus. We do NOT
     add an ID-scoped `display: none` rule here because it would have higher
     specificity than `.flex` and would force every panel to stay hidden
     even after `.hidden` is removed. */

  /* Active category highlight in col2 — set via JS data-active-cat */
</style>

<script>
  const panelEl = document.getElementById('mega-panel');
  if (panelEl) {
    const panel: HTMLElement = panelEl;
    const groupBtns       = panel.querySelectorAll<HTMLButtonElement>('.mega-group-btn');
    const catLinks        = panel.querySelectorAll<HTMLAnchorElement>('.mega-cat-btn');
    const productPanels   = panel.querySelectorAll<HTMLElement>('.mega-product-panel');
    const emptyPanel      = document.getElementById('mega-product-empty');

    function setActiveGroup(gIdx: string, firstCat: string) {
      panel.setAttribute('data-active-group', gIdx);
      // Default the active category to the first non-empty cat of this group.
      setActiveCategory(firstCat);
    }

    function setActiveCategory(slug: string) {
      panel.setAttribute('data-active-cat', slug);
      let matched = false;
      productPanels.forEach((p) => {
        const show = p.getAttribute('data-cat-slug') === slug;
        p.classList.toggle('hidden', !show);
        if (show) matched = true;
      });
      // Highlight active cat link.
      catLinks.forEach((a) => {
        const isActive = a.getAttribute('data-cat-slug') === slug;
        a.classList.toggle('bg-brand/5', isActive);
        a.classList.toggle('text-brand', isActive);
      });
      // Empty state if no product panel matched.
      if (emptyPanel) emptyPanel.classList.toggle('hidden', matched);
    }

    groupBtns.forEach((btn) => {
      const handler = () => setActiveGroup(btn.dataset.groupIdx ?? '0', btn.dataset.firstCat ?? '');
      btn.addEventListener('mouseenter', handler);
      btn.addEventListener('focus',      handler);
    });

    catLinks.forEach((a) => {
      const handler = () => setActiveCategory(a.dataset.catSlug ?? '');
      a.addEventListener('mouseenter', handler);
      a.addEventListener('focus',      handler);
    });

    // Initial paint reflects the data-active-* set in the markup.
    const initialCat = panel.getAttribute('data-active-cat') ?? '';
    setActiveCategory(initialCat);
  }
</script>
