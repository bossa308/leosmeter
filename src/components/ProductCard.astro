---
import type { Product } from '../data/products';
import { getProductBrand } from '../data/products';

interface Props {
  product: Product;
  /** Tighter card with a smaller image area; useful in dense grids. */
  compact?: boolean;
}

const { product, compact = false } = Astro.props;
const brand = getProductBrand(product);

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/products/*.{svg,png,jpg,webp}',
  { eager: true }
);
const imgSrc = images[`/src/assets/products/${product.image}`]?.default;

const cardHeight = compact ? 'h-[360px]' : 'h-[400px]';
---

<article class:list={[
  'product-card group relative overflow-hidden bg-white border border-gray-200 rounded-xl',
  'hover:border-brand/30 hover:shadow-xl transition-all duration-200',
  cardHeight,
]}>
  <!-- Image — fills the top portion. Slight zoom on hover. -->
  <a href={`/products/${product.slug}`} class="absolute inset-x-0 top-0 h-[60%] flex items-center justify-center bg-gray-50 z-0">
    {imgSrc ? (
      <img
        src={imgSrc.src}
        alt={product.name}
        width={600}
        height={450}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-contain p-6 transition-transform duration-300 group-hover:scale-105"
      />
    ) : (
      <span class="text-gray-300 text-5xl font-bold">{product.name.charAt(0)}</span>
    )}
  </a>

  <!-- Body — anchored at the bottom. Slides up on hover, covering more of the image. -->
  <div class="product-card-body absolute inset-x-0 bottom-0 h-[60%] bg-white border-t border-gray-100 px-5 py-4 flex flex-col z-10
              translate-y-[33%] group-hover:translate-y-0 transition-transform duration-300 ease-out
              shadow-[0_-8px_20px_-12px_rgba(0,0,0,0.06)] group-hover:shadow-[0_-12px_24px_-12px_rgba(0,0,0,0.12)]">
    <!-- Always-visible header: badges + title -->
    <div class="flex items-center gap-1.5 flex-wrap mb-1.5">
      <span class:list={[
        'text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full',
        brand === 'Haiwell' ? 'bg-orange-100 text-orange-700' : 'bg-brand/10 text-brand',
      ]}>
        {brand}
      </span>
      {product.model && (
        <span class="text-[10px] font-mono text-gray-400">{product.model}</span>
      )}
    </div>

    <h3 class="font-bold text-gray-900 text-base leading-snug line-clamp-2">
      <a href={`/products/${product.slug}`} class="hover:text-brand transition-colors">
        {product.name}
      </a>
    </h3>

    <!-- Reveal-on-hover details: short → long description, protocols, CTA -->
    <p class="text-sm text-gray-500 leading-relaxed mt-2 line-clamp-3 flex-1">
      {product.shortDescription}
    </p>

    {product.protocols && product.protocols.length > 0 && (
      <div class="mt-2.5 flex flex-wrap gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200 delay-75">
        {product.protocols.slice(0, 3).map((p) => (
          <span class="text-[10px] font-semibold bg-blue-50 text-blue-700 border border-blue-100 px-2 py-0.5 rounded-full">{p}</span>
        ))}
        {product.protocols.length > 3 && (
          <span class="text-[10px] font-semibold text-gray-400">+{product.protocols.length - 3}</span>
        )}
      </div>
    )}

    <a
      href={`/products/${product.slug}`}
      class="mt-3 inline-flex items-center gap-1 text-sm font-bold text-brand hover:underline self-start
             opacity-0 group-hover:opacity-100 transition-opacity duration-200 delay-100"
    >
      ดูรายละเอียด
      <span aria-hidden="true">→</span>
    </a>
  </div>

  <!-- Subtle hint bar at the very bottom edge of the image while not hovered -->
  <div class="absolute bottom-[60%] inset-x-0 h-1 bg-gradient-to-r from-transparent via-brand/40 to-transparent
              opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 pointer-events-none"></div>
</article>
