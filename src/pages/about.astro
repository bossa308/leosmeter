---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import ContactCTA from '../components/ContactCTA.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="เกี่ยวกับเรา — LEOS METER | SME INTER"
  description="บริษัท SME INTER จำกัด ผู้ผลิตและจัดจำหน่ายอุปกรณ์วัดแสดงผลอุตสาหกรรม LEOS METER มากกว่า 10 ปี ผลิตในไทย SAVE BUDGET GET BETTER"
>
  <!-- Page header -->
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <p class="text-cyan text-xs font-bold uppercase tracking-widest mb-2">About Us</p>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3">เกี่ยวกับ LEOS METER</h1>
      <p class="text-blue-200 text-lg max-w-xl">
        มุ่งมั่นพัฒนาสินค้าเพื่ออุตสาหกรรมไทย — SAVE BUDGET GET BETTER
      </p>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-14 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-6 text-gray-700 leading-relaxed">
          <h2 class="text-2xl font-extrabold text-navy">{site.company}</h2>
          <p>
            LEOS METER ดำเนินธุรกิจโดย <strong>{site.company}</strong> ก่อตั้งขึ้นด้วยเจตนารมณ์ที่จะเป็นผู้ผลิตและจัดจำหน่ายอุปกรณ์วัดแสดงผลสำหรับงานอุตสาหกรรมที่เชื่อถือได้ในประเทศไทย ด้วยแนวคิด <strong>"SAVE BUDGET GET BETTER"</strong> — ราคาเหมาะสม คุณภาพดีกว่า
          </p>
          <p>
            เราให้บริการลูกค้าในกลุ่มโรงงานอุตสาหกรรม ผู้รับเหมาไฟฟ้าและระบบ วิศวกรระบบอัตโนมัติ และผู้จัดการอาคาร มาอย่างต่อเนื่องมากกว่า 10 ปี โดยยึดหลักการให้บริการที่ซื่อสัตย์และเชื่อถือได้เป็นสำคัญ
          </p>
          <p>
            สินค้าทุกชิ้นออกแบบและผลิตในประเทศไทย รองรับสภาพแวดล้อมโรงงานจริง พร้อมเอกสารทางเทคนิคภาษาไทยและบริการหลังการขายจากทีมงานผู้เชี่ยวชาญ
          </p>

          <h3 class="text-xl font-extrabold text-navy pt-4">สินค้าที่เราผลิตและจำหน่าย</h3>
          <ul class="space-y-3">
            {[
              { title: 'เพาเวอร์มิเตอร์ & Power Quality Meter', desc: 'วัดและบันทึกการใช้พลังงานไฟฟ้า 3 เฟส ความแม่นยำสูง Class 0.2S–0.5S รองรับ Modbus RTU/TCP และ Ethernet' },
              { title: 'จอแสดงผลขนาดใหญ่ (Jumbo Display / Big Display)', desc: 'LED ตัวเลขขนาด 2.3"–10" มองเห็นชัดเจนจากระยะไกล ผลิตตามความต้องการลูกค้า สั่งทำพิเศษได้' },
              { title: 'นาฬิกาซิงค์เวลา NTP Clock', desc: 'ซิงค์เวลาแม่นยำผ่านเครือข่าย NTP/SNTP สำหรับบันทึกเหตุการณ์และระบบ SCADA — Made in Thailand' },
              { title: 'IoT Gateway & Remote I/O', desc: 'LoRa RF Gateway, MQTT IoT Gateway, Telegram Notify, Ethernet I/O Module สำหรับงาน Industry 4.0' },
              { title: 'Haiwell PLC/HMI', desc: 'PLC และ HMI สำหรับระบบควบคุมอัตโนมัติในโรงงาน รองรับ IEC 61131-3' },
            ].map(({ title, desc }) => (
              <li class="flex items-start gap-2">
                <Icon name="lucide:check-circle" class="w-5 h-5 text-brand mt-0.5 shrink-0" aria-hidden="true" />
                <span><strong>{title}</strong> — {desc}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-brand/5 border border-brand/20 rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-4">ข้อมูลบริษัท</h3>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-gray-500">ชื่อบริษัท</dt>
                <dd class="font-semibold text-gray-900 mt-0.5">{site.company}</dd>
              </div>
              <div>
                <dt class="text-gray-500">แบรนด์สินค้า</dt>
                <dd class="font-semibold text-gray-900 mt-0.5">LEOS METER</dd>
              </div>
              <div>
                <dt class="text-gray-500">ที่อยู่</dt>
                <dd class="font-semibold text-gray-900 mt-0.5 leading-relaxed">{site.address}</dd>
              </div>
              {site.phone.map((p) => (
                <div>
                  <dt class="text-gray-500">โทรศัพท์</dt>
                  <dd class="font-semibold text-gray-900 mt-0.5">
                    <a href={`tel:${p.replace(/-/g, '')}`} class="hover:text-brand">{p}</a>
                  </dd>
                </div>
              ))}
              <div>
                <dt class="text-gray-500">อีเมล</dt>
                <dd class="font-semibold text-gray-900 mt-0.5">
                  <a href={`mailto:${site.email}`} class="hover:text-brand">{site.email}</a>
                </dd>
              </div>
              <div>
                <dt class="text-gray-500">LINE Official</dt>
                <dd class="font-semibold text-gray-900 mt-0.5">{site.lineId}</dd>
              </div>
              <div>
                <dt class="text-gray-500">เวลาทำการ</dt>
                <dd class="font-semibold text-gray-900 mt-0.5">{site.hours}</dd>
              </div>
            </dl>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
            <h3 class="font-bold text-gray-900 mb-4">จุดเด่นของเรา</h3>
            <ul class="space-y-3 text-sm">
              {[
                'ประสบการณ์มากกว่า 10 ปี',
                'ผลิตในประเทศไทย Made in TH',
                'ทีมวิศวกรให้คำปรึกษาฟรี',
                'สต็อกสินค้าพร้อมจัดส่ง',
                'บริการหลังการขายระยะยาว',
              ].map((item) => (
                <li class="flex items-center gap-2">
                  <Icon name="lucide:check" class="w-4 h-4 text-green-600 shrink-0" aria-hidden="true" />
                  <span class="text-gray-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <a href="/contact" class="btn-primary w-full text-center block py-3">
            ติดต่อสอบถาม
          </a>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
