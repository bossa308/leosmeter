---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { allCategories } from '../../data/categories';
import { getProductsByCategory } from '../../data/products';
import ContactCTA from '../../components/ContactCTA.astro';

export function getStaticPaths() {
  return allCategories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const products = getProductsByCategory(category.slug);
---

<BaseLayout
  title={`${category.name} — LEOS METER`}
  description={`${category.name} อุปกรณ์วัดแสดงผลอุตสาหกรรมจาก LEOS METER | SME INTER`}
>
  <!-- Page header -->
  <section class="bg-gray-50 border-b border-gray-200 py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <nav class="text-sm text-gray-500 mb-3" aria-label="breadcrumb">
        <a href="/products" class="hover:text-brand transition-colors">สินค้าทั้งหมด</a>
        <span class="mx-1" aria-hidden="true">›</span>
        <span class="text-gray-900">{category.name}</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">{category.name}</h1>
      <p class="text-gray-500 mt-2">{products.length} รายการ</p>
    </div>
  </section>

  <!-- Products -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-400 text-lg mb-6">ยังไม่มีสินค้าในหมวดนี้</p>
        <a href="/products" class="btn-primary inline-block">ดูสินค้าทั้งหมด</a>
      </div>
    )}

    <div class="mt-10 pt-8 border-t border-gray-200">
      <a href="/products" class="text-brand font-semibold text-sm hover:underline">
        ← กลับสู่รายการสินค้าทั้งหมด
      </a>
    </div>
  </div>

  <ContactCTA />
</BaseLayout>
