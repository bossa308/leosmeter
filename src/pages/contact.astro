---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
---

<BaseLayout
  title="ติดต่อเรา — LEOS METER"
  description="ติดต่อ LEOS METER | SME INTER สอบถามราคาสินค้า ขอใบเสนอราคา หรือขอรับคำปรึกษาด้านเทคนิค"
>
  <!-- Page header -->
  <section class="bg-navy text-white py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <p class="text-cyan text-xs font-bold uppercase tracking-widest mb-2">Contact Us</p>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2">ติดต่อสอบถาม</h1>
      <p class="text-blue-200">{site.hours}</p>
    </div>
  </section>

  <section class="py-14 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Form (wider) -->
        <div class="lg:col-span-3">
          <h2 class="text-xl font-bold text-gray-900 mb-6">ส่งข้อความหาเรา</h2>
          <ContactForm />
        </div>

        <!-- Contact info sidebar -->
        <div class="lg:col-span-2 space-y-5">
          <h2 class="text-xl font-bold text-gray-900">ช่องทางติดต่อ</h2>

          <div class="space-y-4">
            {site.phone.map((p) => (
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0">
                  <Icon name="lucide:phone" class="w-5 h-5 text-brand" aria-hidden="true" />
                </div>
                <div>
                  <p class="font-semibold text-gray-900 text-sm">โทรศัพท์</p>
                  <a href={`tel:${p.replace(/-/g, '')}`} class="text-gray-600 text-sm mt-0.5 hover:text-brand transition-colors block">{p}</a>
                  <p class="text-gray-400 text-xs mt-0.5">{site.hours}</p>
                </div>
              </div>
            ))}

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center shrink-0">
                <Icon name="lucide:message-circle" class="w-5 h-5 text-green-700" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">LINE Official Account</p>
                <a
                  href={site.line}
                  target="_blank"
                  rel="noopener"
                  class="text-gray-600 text-sm mt-0.5 hover:text-brand transition-colors block"
                >
                  {site.lineId}
                </a>
                <p class="text-gray-400 text-xs mt-0.5">ตอบกลับเร็วที่สุด</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0">
                <Icon name="lucide:mail" class="w-5 h-5 text-brand" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">อีเมล</p>
                <a
                  href={`mailto:${site.email}`}
                  class="text-gray-600 text-sm mt-0.5 hover:text-brand transition-colors block"
                >
                  {site.email}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0">
                <Icon name="lucide:map-pin" class="w-5 h-5 text-brand" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold text-gray-900 text-sm">ที่อยู่</p>
                <p class="text-gray-600 text-sm mt-0.5 leading-relaxed">{site.address}</p>
              </div>
            </div>
          </div>

          <!-- TODO: Replace with Google Maps embed once address is confirmed -->
          <div class="h-52 bg-gray-100 border border-gray-200 rounded-xl flex items-center justify-center text-gray-400 text-sm">
            <div class="text-center">
              <Icon name="lucide:map" class="w-8 h-8 mx-auto mb-2 opacity-40" aria-hidden="true" />
              <p>แผนที่จะแสดงที่นี่</p>
            </div>
          </div>

          <div class="bg-brand/5 border border-brand/20 rounded-xl p-4">
            <p class="text-sm font-bold text-brand mb-1">เวลาทำการ</p>
            <p class="text-sm text-gray-600">{site.hours}</p>
            <p class="text-sm text-gray-400 mt-1">หยุดวันอาทิตย์และวันหยุดนักขัตฤกษ์</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
