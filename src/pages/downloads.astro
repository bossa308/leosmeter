---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { downloads, docTypeLabel, docTypeColor } from '../data/downloads';
import { downloadFileExists } from '../lib/downloads-fs';

const docTypes = [...new Set(downloads.map((d) => d.docType))];
const categories = [...new Set(downloads.map((d) => d.category))];

const downloadsWithStatus = downloads.map((d) => ({
  ...d,
  available: downloadFileExists(d.filename),
}));
const availableCount = downloadsWithStatus.filter((d) => d.available).length;

const categoryLabel: Record<string, string> = {
  'ac-meter':       'AC Meter',
  'process-meter':  'Process Meter',
  'lora':           'LoRa Wireless',
  'notify-telegram':'Telegram Notify',
  'iot-mqtt':       'IoT / MQTT',
  'ethernet-io':    'Ethernet I/O',
  'big-display':    'Big Display',
  'ntp-clock':      'NTP Clock',
};
---

<BaseLayout
  title="Download Center — คู่มือและเอกสาร | LEOS METER"
  description="ดาวน์โหลด Datasheet คู่มือการใช้งาน Firmware Wiring Diagram และ Modbus Register Map สำหรับสินค้า LEOS METER ทุกรุ่น"
>
  <!-- Page header -->
  <section class="bg-navy text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 bg-brand rounded-xl flex items-center justify-center shrink-0">
          <Icon name="lucide:download" class="w-6 h-6 text-white" aria-hidden="true" />
        </div>
        <div>
          <p class="text-cyan text-xs font-bold uppercase tracking-widest mb-1">Support</p>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-tight">Download Center</h1>
          <p class="text-blue-200 mt-2">Datasheet · คู่มือ · Firmware · Wiring Diagram · Modbus Register Map</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Filters + Table -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Filter bar -->
    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6 flex flex-col sm:flex-row gap-4">
      <!-- Search -->
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="dl-search"
          type="search"
          placeholder="ค้นหา Model หรือชื่อสินค้า..."
          class="w-full pl-9 pr-4 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand"
          autocomplete="off"
        />
      </div>

      <!-- Doc type filter -->
      <select id="dl-type" class="text-sm border border-gray-200 rounded-lg px-3 py-2.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
        <option value="">ประเภทเอกสารทั้งหมด</option>
        {docTypes.map((t) => (
          <option value={t}>{docTypeLabel[t]}</option>
        ))}
      </select>

      <!-- Category filter -->
      <select id="dl-cat" class="text-sm border border-gray-200 rounded-lg px-3 py-2.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand">
        <option value="">หมวดหมู่ทั้งหมด</option>
        {categories.map((c) => (
          <option value={c}>{categoryLabel[c] ?? c}</option>
        ))}
      </select>
    </div>

    <!-- Stats row -->
    <p id="dl-count" class="text-sm text-gray-500 mb-4">{downloads.length} รายการ</p>

    {availableCount < downloads.length && (
      <div class="mb-4 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 text-sm text-amber-800 flex items-start gap-2">
        <Icon name="lucide:info" class="w-4 h-4 mt-0.5 shrink-0" aria-hidden="true" />
        <span>
          เอกสารบางรายการยังไม่ได้อัปโหลด — กดปุ่ม <span class="font-semibold">ขอเอกสาร</span> เพื่อให้ทีมงานส่งให้ภายใน 1 วันทำการ
        </span>
      </div>
    )}

    <!-- Downloads table -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="dl-table">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200 text-left">
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">Model</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">สินค้า</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">เอกสาร</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">ภาษา</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">Version</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap">อัปเดต</th>
              <th class="px-5 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wide whitespace-nowrap"></th>
            </tr>
          </thead>
          <tbody id="dl-body">
            {downloadsWithStatus.map((dl) => (
              <tr
                class="dl-row border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors"
                data-search={`${dl.model} ${dl.productName} ${dl.label}`.toLowerCase()}
                data-type={dl.docType}
                data-cat={dl.category}
              >
                <td class="px-5 py-3.5">
                  <span class="font-mono font-bold text-navy text-sm">{dl.model}</span>
                </td>
                <td class="px-5 py-3.5 text-gray-700">{dl.productName}</td>
                <td class="px-5 py-3.5">
                  <div class="flex items-center gap-2">
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full whitespace-nowrap ${docTypeColor[dl.docType]}`}>
                      {docTypeLabel[dl.docType]}
                    </span>
                    <span class="text-gray-600 text-sm">{dl.label}</span>
                  </div>
                </td>
                <td class="px-5 py-3.5 text-gray-500 text-xs">{dl.lang}</td>
                <td class="px-5 py-3.5 text-gray-500 text-xs">{dl.version ?? '—'}</td>
                <td class="px-5 py-3.5 text-gray-500 text-xs whitespace-nowrap">
                  {new Date(dl.updatedAt).toLocaleDateString('th-TH', { year: 'numeric', month: 'short' })}
                </td>
                <td class="px-5 py-3.5">
                  {dl.available ? (
                    <a
                      href={`/downloads/${dl.filename}`}
                      class="inline-flex items-center gap-1.5 text-xs font-semibold text-brand border border-brand/30 hover:bg-brand hover:text-white px-3 py-1.5 rounded-lg transition-colors whitespace-nowrap"
                      title={`Download ${dl.label}`}
                      download
                    >
                      <Icon name="lucide:download" class="w-3.5 h-3.5" aria-hidden="true" />
                      Download
                    </a>
                  ) : (
                    <a
                      href={`/contact?subject=${encodeURIComponent('ขอเอกสาร ' + dl.label + ' (' + dl.model + ')')}`}
                      class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-500 border border-gray-200 hover:border-brand hover:text-brand px-3 py-1.5 rounded-lg transition-colors whitespace-nowrap"
                      title="ขอเอกสารจากทีมงาน"
                    >
                      <Icon name="lucide:mail" class="w-3.5 h-3.5" aria-hidden="true" />
                      ขอเอกสาร
                    </a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Empty state -->
    <p id="dl-empty" class="hidden text-center text-gray-400 py-16 text-sm">ไม่พบเอกสารที่ค้นหา</p>

    <!-- Note -->
    <div class="mt-8 bg-blue-50 border border-blue-200 rounded-xl p-5 flex items-start gap-3">
      <Icon name="lucide:info" class="w-5 h-5 text-brand shrink-0 mt-0.5" aria-hidden="true" />
      <div class="text-sm text-gray-600 leading-relaxed">
        <p class="font-semibold text-gray-800 mb-1">ไม่พบเอกสารที่ต้องการ?</p>
        <p>
          ติดต่อทีมสนับสนุน LINE: <a href="https://line.me/ti/p/~@leosmeter" class="text-brand font-semibold hover:underline" target="_blank" rel="noopener">@leosmeter</a>
          หรือ <a href="/contact" class="text-brand font-semibold hover:underline">ส่งข้อความถามทีมงาน</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput  = document.getElementById('dl-search')  as HTMLInputElement;
  const typeSelect   = document.getElementById('dl-type')    as HTMLSelectElement;
  const catSelect    = document.getElementById('dl-cat')     as HTMLSelectElement;
  const rows         = document.querySelectorAll<HTMLElement>('.dl-row');
  const emptyMsg     = document.getElementById('dl-empty')!;
  const countEl      = document.getElementById('dl-count')!;

  function filter() {
    const q    = searchInput.value.toLowerCase().trim();
    const type = typeSelect.value;
    const cat  = catSelect.value;
    let visible = 0;

    rows.forEach((row) => {
      const matchSearch = !q    || row.dataset.search!.includes(q);
      const matchType   = !type || row.dataset.type   === type;
      const matchCat    = !cat  || row.dataset.cat    === cat;
      const show = matchSearch && matchType && matchCat;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    emptyMsg.classList.toggle('hidden', visible > 0);
    countEl.textContent = `${visible} รายการ`;
  }

  searchInput.addEventListener('input', filter);
  typeSelect.addEventListener('change', filter);
  catSelect.addEventListener('change', filter);
</script>
