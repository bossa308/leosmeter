---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import SolutionCard from '../components/SolutionCard.astro';
import BlogCard from '../components/BlogCard.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { Icon } from 'astro-icon/components';
import { getFeaturedProducts } from '../data/products';
import { solutions } from '../data/solutions';
import { site } from '../data/site';
import { getCollection } from 'astro:content';

const featured = getFeaturedProducts();
const tutorials = (await getCollection('tutorial'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const stats = [
  { value: '10+', label: 'ปีประสบการณ์', icon: 'lucide:award' },
  { value: '100+', label: 'รายการสินค้า', icon: 'lucide:package' },
  { value: 'Made in TH', label: 'ผลิตในไทย', icon: 'lucide:flag' },
  { value: '24h', label: 'บริการหลังขาย', icon: 'lucide:headphones' },
];
---

<BaseLayout title="LEOS METER — เพาเวอร์มิเตอร์ จอแสดงผล นาฬิกา NTP อุตสาหกรรม" description="LEOS METER by SME INTER จำหน่ายเพาเวอร์มิเตอร์ จอแสดงผล LED นาฬิกา NTP และ Haiwell PLC/HMI สำหรับโรงงานอุตสาหกรรม ผลิตในไทย SAVE BUDGET GET BETTER">

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Trust / Stats -->
  <section class="bg-white border-b border-gray-100 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(({ value, label, icon }) => (
          <div class="flex flex-col items-center text-center gap-2">
            <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center">
              <Icon name={icon} class="w-6 h-6 text-brand" aria-hidden="true" />
            </div>
            <p class="text-2xl font-extrabold text-navy">{value}</p>
            <p class="text-sm text-gray-500">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Featured Products -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-xs font-bold text-brand uppercase tracking-widest mb-1">สินค้าแนะนำ</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-navy">สินค้าขายดี</h2>
        </div>
        <a href="/products" class="text-sm font-semibold text-brand hover:underline hidden sm:block">
          ดูสินค้าทั้งหมด →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {featured.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
      <div class="mt-6 text-center sm:hidden">
        <a href="/products" class="text-sm font-semibold text-brand hover:underline">
          ดูสินค้าทั้งหมด →
        </a>
      </div>
    </div>
  </section>

  <!-- 4. About / Made in Thailand -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-bold text-brand uppercase tracking-widest mb-2">เกี่ยวกับเรา</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-navy mb-4">
            SME INTER — ผลิตในไทย<br />
            <span class="text-brand">เพื่ออุตสาหกรรมไทย</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            บริษัท SME INTER จำกัด ก่อตั้งมากกว่า 10 ปี มุ่งมั่นพัฒนาและผลิตอุปกรณ์วัดแสดงผล
            สำหรับอุตสาหกรรมไทยโดยเฉพาะ ทั้งเพาเวอร์มิเตอร์, จอแสดงผล LED ขนาดใหญ่,
            นาฬิกาซิงค์เวลา NTP และโซลูชัน IoT/SCADA
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            สินค้าทุกชิ้นออกแบบและผลิตในประเทศไทย รองรับสภาพแวดล้อมโรงงานจริง
            มีทีมวิศวกรให้คำปรึกษาด้านเทคนิคและบริการหลังการขาย
          </p>
          <p class="text-xl font-extrabold text-brand tracking-wider">SAVE BUDGET GET BETTER</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { icon: 'lucide:shield-check', title: 'คุณภาพมาตรฐาน', desc: 'ผ่านการทดสอบตามมาตรฐานอุตสาหกรรม' },
            { icon: 'lucide:wrench', title: 'บริการหลังขาย', desc: 'ทีมวิศวกรพร้อมสนับสนุน' },
            { icon: 'lucide:flag', title: 'Made in Thailand', desc: 'ออกแบบและผลิตในไทย' },
            { icon: 'lucide:trending-down', title: 'ราคาเหมาะสม', desc: 'ประหยัดงบ ได้คุณภาพดีกว่า' },
          ].map(({ icon, title, desc }) => (
            <div class="bg-gray-50 rounded-xl p-4">
              <Icon name={icon} class="w-6 h-6 text-brand mb-2" aria-hidden="true" />
              <p class="font-bold text-navy text-sm mb-1">{title}</p>
              <p class="text-xs text-gray-500 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Solutions -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-xs font-bold text-brand uppercase tracking-widest mb-1">โซลูชัน</p>
          <h2 class="text-2xl md:text-3xl font-extrabold text-navy">โซลูชันอุตสาหกรรม</h2>
        </div>
        <a href="/solutions" class="text-sm font-semibold text-brand hover:underline hidden sm:block">
          ดูทั้งหมด →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {solutions.slice(0, 6).map((s) => (
          <SolutionCard solution={s} />
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Tutorial & FAQ -->
  {tutorials.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-xs font-bold text-brand uppercase tracking-widest mb-1">ช่วยเหลือ</p>
            <h2 class="text-2xl md:text-3xl font-extrabold text-navy">บทความ & คู่มือ</h2>
          </div>
          <a href="/tutorial" class="text-sm font-semibold text-brand hover:underline hidden sm:block">
            ดูทั้งหมด →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {tutorials.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 7. Contact CTA -->
  <ContactCTA />
</BaseLayout>
