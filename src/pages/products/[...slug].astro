---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { products, getProductBySlug } from '../../data/products';
import ContactCTA from '../../components/ContactCTA.astro';
import { site } from '../../data/site';

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/products/*.{svg,png,jpg,webp}',
  { eager: true }
);
const imgSrc = images[`/src/assets/products/${product.image}`]?.default;
---

<BaseLayout
  title={`${product.name} — LEOS METER`}
  description={product.shortDescription}
>
  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2" aria-label="breadcrumb">
    <ol class="flex items-center gap-1 text-sm text-gray-500 flex-wrap">
      <li><a href="/" class="hover:text-brand transition-colors">หน้าแรก</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li><a href="/products" class="hover:text-brand transition-colors">สินค้า</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li class="text-gray-900 font-medium truncate">{product.name}</li>
    </ol>
  </nav>

  <!-- Main product layout -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Product image -->
      <div class="aspect-[4/3] bg-gray-50 rounded-xl overflow-hidden flex items-center justify-center border border-gray-200">
        {imgSrc ? (
          <img
            src={imgSrc.src}
            alt={product.name}
            width={800}
            height={600}
            loading="eager"
            decoding="async"
            class="w-full h-full object-contain p-6"
          />
        ) : (
          <span class="text-gray-300 text-6xl font-bold">{product.name.charAt(0)}</span>
        )}
      </div>

      <!-- Product info -->
      <div>
        <span class="inline-block text-xs font-semibold text-brand bg-brand/10 px-2.5 py-1 rounded-full mb-3">
          {product.category}
        </span>

        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 leading-tight mb-3">
          {product.name}
        </h1>
        <p class="text-gray-600 leading-relaxed mb-6">{product.shortDescription}</p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a
            href="/contact"
            class="btn-primary flex-1 flex items-center justify-center gap-2 py-3"
          >
            <Icon name="lucide:phone" class="w-4 h-4" aria-hidden="true" />
            ติดต่อสอบถาม
          </a>
          <a
            href={site.line}
            target="_blank"
            rel="noopener"
            class="flex-1 flex items-center justify-center gap-2 py-3 bg-green-500 text-white font-bold rounded-lg hover:bg-green-400 transition-colors"
          >
            <Icon name="lucide:message-circle" class="w-4 h-4" aria-hidden="true" />
            LINE {site.lineId}
          </a>
        </div>

        <!-- Specs table -->
        {product.specs.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-3">ข้อมูลจำเพาะ</h2>
            <div class="border border-gray-200 rounded-xl overflow-hidden">
              <table class="w-full specs-table">
                <tbody>
                  {product.specs.map((spec, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
                      <th scope="row">{spec.label}</th>
                      <td>{spec.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Features + Description -->
    <div class="mt-12 pt-8 border-t border-gray-200 grid md:grid-cols-2 gap-10">
      {product.features.length > 0 && (
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-4">คุณสมบัติเด่น</h2>
          <ul class="space-y-2">
            {product.features.map((f) => (
              <li class="flex items-start gap-2 text-gray-700 text-sm">
                <Icon name="lucide:check-circle" class="w-5 h-5 text-brand mt-0.5 shrink-0" aria-hidden="true" />
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4">รายละเอียดสินค้า</h2>
        <p class="text-gray-600 leading-relaxed text-sm">{product.description}</p>
      </div>
    </div>

    <!-- Back link -->
    <div class="mt-10">
      <a href="/products" class="inline-flex items-center gap-2 text-brand font-semibold hover:underline text-sm">
        <Icon name="lucide:arrow-left" class="w-4 h-4" aria-hidden="true" />
        กลับสู่รายการสินค้า
      </a>
    </div>
  </div>

  <ContactCTA />
</BaseLayout>
