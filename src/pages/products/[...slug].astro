---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { products, getProductBySlug } from '../../data/products';
import { site } from '../../data/site';
import { downloadFileExists } from '../../lib/downloads-fs';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/products/*.{svg,png,jpg,webp}',
  { eager: true }
);
const imgSrc = images[`/src/assets/products/${product.image}`]?.default;

const related = (product.relatedProducts ?? [])
  .map((slug) => getProductBySlug(slug))
  .filter(Boolean) as typeof products;

const productDownloads = (product.downloads ?? []).map((dl) => ({
  ...dl,
  available: downloadFileExists(dl.filename),
}));

// Cross-link tutorials that mention this product (by slug or model number).
const allTutorials = await getCollection('tutorial');
const productKeywords = [
  product.slug,
  product.id,
  product.model,
  ...(product.tags ?? []),
].filter(Boolean).map((s) => String(s).toLowerCase());

const relatedTutorials = allTutorials
  .filter((t) => {
    const haystack = (t.data.title + ' ' + t.data.description + ' ' + (t.data.tags ?? []).join(' ') + ' ' + t.body).toLowerCase();
    return productKeywords.some((k) => k && haystack.includes(k));
  })
  .slice(0, 4);

const protocolColors: Record<string, string> = {
  'Modbus RTU':    'bg-blue-100 text-blue-800',
  'Modbus TCP':    'bg-indigo-100 text-indigo-800',
  'RS485':         'bg-slate-100 text-slate-700',
  'Ethernet':      'bg-cyan-100 text-cyan-800',
  'MQTT':          'bg-green-100 text-green-700',
  'LoRa':          'bg-teal-100 text-teal-800',
  'NTP':           'bg-violet-100 text-violet-800',
  'SNTP':          'bg-violet-100 text-violet-800',
  'Telegram Bot API': 'bg-sky-100 text-sky-800',
};

const docTypeLabel: Record<string, string> = {
  datasheet: 'Datasheet', manual: 'คู่มือการใช้งาน', firmware: 'Firmware',
  software: 'Software', wiring: 'Wiring Diagram',
  'register-map': 'Modbus Register Map', quickstart: 'Quick Start Guide',
};
const docTypeIcon: Record<string, string> = {
  datasheet: 'lucide:file-text', manual: 'lucide:book-open', firmware: 'lucide:cpu',
  software: 'lucide:code-2', wiring: 'lucide:git-branch',
  'register-map': 'lucide:table-2', quickstart: 'lucide:rocket',
};
---

<BaseLayout
  title={`${product.model ? product.model + ' — ' : ''}${product.name} | LEOS METER`}
  description={product.shortDescription}
>
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200" aria-label="breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-1.5 text-xs text-gray-500 flex-wrap">
        <li><a href="/" class="hover:text-brand transition-colors">หน้าแรก</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li><a href="/products" class="hover:text-brand transition-colors">สินค้า</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium">{product.name}</li>
      </ol>
    </div>
  </nav>

  <!-- ===== TOP SECTION: Image + Info ===== -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- LEFT: Product image -->
      <div>
        <div class="aspect-[4/3] bg-gray-50 rounded-2xl overflow-hidden flex items-center justify-center border border-gray-200 sticky top-24">
          {imgSrc ? (
            <img
              src={imgSrc.src}
              alt={product.name}
              width={800}
              height={600}
              loading="eager"
              decoding="async"
              class="w-full h-full object-contain p-10"
            />
          ) : (
            <div class="flex flex-col items-center gap-3 text-gray-200">
              <Icon name="lucide:package" class="w-24 h-24" aria-hidden="true" />
              <span class="text-lg font-bold">{product.name.charAt(0)}</span>
            </div>
          )}
        </div>

        <!-- Trust badges below image -->
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1 text-xs text-gray-500 bg-gray-50 border border-gray-200 px-2.5 py-1 rounded-full">
            <Icon name="lucide:flag" class="w-3.5 h-3.5 text-brand" aria-hidden="true" />
            Made in Thailand
          </span>
          <span class="inline-flex items-center gap-1 text-xs text-gray-500 bg-gray-50 border border-gray-200 px-2.5 py-1 rounded-full">
            <Icon name="lucide:headphones" class="w-3.5 h-3.5 text-brand" aria-hidden="true" />
            Technical Support
          </span>
          <span class="inline-flex items-center gap-1 text-xs text-gray-500 bg-gray-50 border border-gray-200 px-2.5 py-1 rounded-full">
            <Icon name="lucide:wrench" class="w-3.5 h-3.5 text-brand" aria-hidden="true" />
            Customizable
          </span>
        </div>
      </div>

      <!-- RIGHT: Product info -->
      <div>
        <!-- Category + Model -->
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-bold text-brand bg-brand/10 px-2.5 py-1 rounded-full uppercase tracking-wider">
            {product.category.replace(/-/g, ' ')}
          </span>
          {product.model && (
            <span class="text-xs font-mono text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">
              Model: {product.model}
            </span>
          )}
        </div>

        <h1 class="text-2xl md:text-3xl font-extrabold text-navy leading-tight mb-3">
          {product.name}
        </h1>
        <p class="text-gray-600 leading-relaxed mb-5 text-base">{product.shortDescription}</p>

        <!-- Protocol badges -->
        {product.protocols && product.protocols.length > 0 && (
          <div class="mb-5">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Protocol Support</p>
            <div class="flex flex-wrap gap-1.5">
              {product.protocols.map((p) => (
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${protocolColors[p] ?? 'bg-gray-100 text-gray-700'}`}>
                  {p}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Applications -->
        {product.applications && product.applications.length > 0 && (
          <div class="mb-6">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Applications</p>
            <div class="flex flex-wrap gap-1.5">
              {product.applications.map((a) => (
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-orange-50 text-orange-700 border border-orange-200">
                  {a}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- CTA buttons -->
        <div class="flex flex-col gap-2.5 mb-6">
          <a
            href={`/contact?model=${encodeURIComponent(product.model ?? product.name)}`}
            class="flex items-center justify-center gap-2 bg-brand text-white font-bold px-6 py-3.5 rounded-lg hover:bg-brand/90 transition-colors"
          >
            <Icon name="lucide:send" class="w-4 h-4" aria-hidden="true" />
            ขอใบเสนอราคา / ปรึกษาฝ่ายขาย
          </a>
          <a
            href={site.line}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 bg-green-500 text-white font-bold px-6 py-3.5 rounded-lg hover:bg-green-400 transition-colors"
          >
            <Icon name="lucide:message-circle" class="w-4 h-4" aria-hidden="true" />
            ส่งรุ่นนี้ให้ฝ่ายขายผ่าน LINE {site.lineId}
          </a>
          {productDownloads.length > 0 && (
            <a
              href="#downloads"
              class="flex items-center justify-center gap-2 border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-lg hover:border-brand hover:text-brand transition-colors text-sm"
            >
              <Icon name="lucide:download" class="w-4 h-4" aria-hidden="true" />
              ดาวน์โหลดคู่มือ / Datasheet
            </a>
          )}
        </div>

        <!-- Quick specs snapshot -->
        {product.specs.length > 0 && (
          <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden">
            <div class="px-4 py-2.5 border-b border-gray-200">
              <p class="text-xs font-bold text-gray-500 uppercase tracking-wider">Key Specifications</p>
            </div>
            <table class="w-full text-sm">
              <tbody>
                {product.specs.slice(0, 6).map((spec, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
                    <th class="text-left px-4 py-2.5 text-gray-500 font-medium text-xs w-40 whitespace-nowrap">{spec.label}</th>
                    <td class="px-4 py-2.5 text-gray-800 font-semibold text-xs">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            {product.specs.length > 6 && (
              <div class="px-4 py-2.5 border-t border-gray-200">
                <a href="#specifications" class="text-xs text-brand font-semibold hover:underline">
                  ดูสเปคทั้งหมด ({product.specs.length} รายการ) →
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ===== TAB CONTENT SECTIONS ===== -->
  <div class="border-t border-gray-200 bg-gray-50/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section nav anchors -->
      <nav class="flex gap-6 border-b border-gray-200 overflow-x-auto scrollbar-none sticky top-16 bg-gray-50/95 backdrop-blur-sm z-30 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8" aria-label="รายละเอียดสินค้า">
        <a href="#overview"        class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Overview</a>
        <a href="#features"        class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Features</a>
        <a href="#specifications"  class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Specifications</a>
        {productDownloads.length > 0 && (
          <a href="#downloads"     class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Downloads</a>
        )}
        {relatedTutorials.length > 0 && (
          <a href="#tutorials"     class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Tutorials</a>
        )}
        {product.faqs && product.faqs.length > 0 && (
          <a href="#faq"           class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">FAQ</a>
        )}
        {related.length > 0 && (
          <a href="#related"       class="py-4 text-sm font-semibold text-gray-500 hover:text-brand border-b-2 border-transparent hover:border-brand transition-colors whitespace-nowrap">Related Products</a>
        )}
      </nav>

      <!-- ── Overview ── -->
      <section id="overview" class="py-12 border-b border-gray-200 scroll-mt-32">
        <h2 class="text-xl font-extrabold text-navy mb-4">Overview</h2>
        <p class="text-gray-600 leading-relaxed max-w-3xl">{product.description}</p>
      </section>

      <!-- ── Features ── -->
      {product.features.length > 0 && (
        <section id="features" class="py-12 border-b border-gray-200 scroll-mt-32">
          <h2 class="text-xl font-extrabold text-navy mb-6">Key Features</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {product.features.map((f) => (
              <div class="flex items-start gap-3 bg-white border border-gray-200 rounded-xl p-4">
                <div class="w-6 h-6 bg-brand/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="lucide:check" class="w-3.5 h-3.5 text-brand" aria-hidden="true" />
                </div>
                <span class="text-sm text-gray-700 leading-relaxed">{f}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- ── Specifications ── -->
      {product.specs.length > 0 && (
        <section id="specifications" class="py-12 border-b border-gray-200 scroll-mt-32">
          <h2 class="text-xl font-extrabold text-navy mb-6">Technical Specifications</h2>
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden max-w-3xl">
            <table class="w-full">
              <tbody>
                {product.specs.map((spec, i) => (
                  <tr class={`border-b border-gray-100 last:border-0 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                    <th class="text-left px-5 py-3 text-gray-500 font-semibold text-sm w-44 align-top">{spec.label}</th>
                    <td class="px-5 py-3 text-gray-800 text-sm">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <!-- ── Downloads ── -->
      {productDownloads.length > 0 && (
        <section id="downloads" class="py-12 border-b border-gray-200 scroll-mt-32">
          <h2 class="text-xl font-extrabold text-navy mb-2">Downloads</h2>
          <p class="text-sm text-gray-500 mb-6">ไฟล์เอกสารและคู่มือสำหรับรุ่น {product.model ?? product.name}</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {productDownloads.map((dl) => (
              <div class="bg-white border border-gray-200 rounded-xl p-4 flex items-start gap-3 hover:border-brand/30 hover:shadow-sm transition-all">
                <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0">
                  <Icon name={docTypeIcon[dl.type] ?? 'lucide:file'} class="w-5 h-5 text-brand" aria-hidden="true" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-gray-800 text-sm leading-snug mb-1">{dl.label}</p>
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
                      {docTypeLabel[dl.type] ?? dl.type}
                    </span>
                    {dl.lang && <span class="text-xs text-gray-400">{dl.lang}</span>}
                    {dl.version && <span class="text-xs text-gray-400">{dl.version}</span>}
                    {!dl.available && (
                      <span class="text-[10px] text-amber-700 bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded-full font-semibold">
                        ขอจากทีมงาน
                      </span>
                    )}
                  </div>
                </div>
                {dl.available ? (
                  <a
                    href={`/downloads/${dl.filename}`}
                    class="shrink-0 text-brand hover:bg-brand hover:text-white border border-brand/30 rounded-lg p-1.5 transition-colors"
                    title={`Download ${dl.label}`}
                    aria-label={`Download ${dl.label}`}
                    download
                  >
                    <Icon name="lucide:download" class="w-4 h-4" aria-hidden="true" />
                  </a>
                ) : (
                  <a
                    href={`/contact?subject=${encodeURIComponent('ขอเอกสาร ' + dl.label + ' (' + (product.model ?? product.name) + ')')}`}
                    class="shrink-0 text-gray-500 hover:text-brand hover:border-brand border border-gray-200 rounded-lg p-1.5 transition-colors"
                    title="ขอเอกสารจากทีมงาน"
                    aria-label="ขอเอกสารจากทีมงาน"
                  >
                    <Icon name="lucide:mail" class="w-4 h-4" aria-hidden="true" />
                  </a>
                )}
              </div>
            ))}
          </div>
          <p class="mt-4 text-xs text-gray-400">
            * ไม่พบไฟล์ที่ต้องการ? <a href="/contact" class="text-brand hover:underline">ติดต่อฝ่ายสนับสนุนทางเทคนิค</a>
          </p>
        </section>
      )}

      <!-- ── FAQ ── -->
      {product.faqs && product.faqs.length > 0 && (
        <section id="faq" class="py-12 border-b border-gray-200 scroll-mt-32">
          <h2 class="text-xl font-extrabold text-navy mb-6">FAQ — คำถามที่พบบ่อย</h2>
          <div class="space-y-3 max-w-3xl">
            {product.faqs.map((faq, i) => (
              <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
                <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-gray-800 text-sm hover:text-brand transition-colors">
                  <span>{faq.q}</span>
                  <Icon name="lucide:chevron-down" class="w-4 h-4 shrink-0 transition-transform duration-200 group-open:rotate-180 text-gray-400" aria-hidden="true" />
                </summary>
                <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100">
                  <p class="pt-3">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- ── Tutorials & Knowledge Base ── -->
      {relatedTutorials.length > 0 && (
        <section id="tutorials" class="py-12 border-b border-gray-200 scroll-mt-32">
          <div class="flex items-end justify-between gap-4 mb-6">
            <div>
              <h2 class="text-xl font-extrabold text-navy">Tutorials & Knowledge Base</h2>
              <p class="text-sm text-gray-500 mt-1">บทความที่เกี่ยวข้องกับรุ่น {product.model ?? product.name}</p>
            </div>
            <a href="/tutorial" class="text-xs font-semibold text-brand hover:underline whitespace-nowrap">ดูทั้งหมด →</a>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            {relatedTutorials.map((t) => (
              <a
                href={`/tutorial/${t.slug}`}
                class="group bg-white border border-gray-200 rounded-xl p-5 hover:border-brand/30 hover:shadow-sm transition-all flex gap-4"
              >
                <div class="w-10 h-10 bg-brand/10 rounded-lg flex items-center justify-center shrink-0">
                  <Icon
                    name={
                      t.data.category === 'firmware' ? 'lucide:cpu' :
                      t.data.category === 'manual'   ? 'lucide:book-open' :
                      t.data.category === 'qa'       ? 'lucide:help-circle' :
                                                       'lucide:graduation-cap'
                    }
                    class="w-5 h-5 text-brand"
                    aria-hidden="true"
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">{t.data.category}</p>
                  <p class="font-bold text-gray-800 text-sm leading-snug group-hover:text-brand transition-colors">{t.data.title}</p>
                  <p class="text-xs text-gray-500 mt-1 leading-relaxed line-clamp-2">{t.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- ── Related Products ── -->
      {related.length > 0 && (
        <section id="related" class="py-12 scroll-mt-32">
          <h2 class="text-xl font-extrabold text-navy mb-6">Related Products</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {related.map((rel) => {
              const relImg = images[`/src/assets/products/${rel.image}`]?.default;
              return (
                <a
                  href={`/products/${rel.slug}`}
                  class="group bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-brand/30 transition-all flex gap-4"
                >
                  <div class="w-20 h-20 bg-gray-50 rounded-lg overflow-hidden flex items-center justify-center shrink-0">
                    {relImg ? (
                      <img src={relImg.src} alt={rel.name} width={80} height={80} class="object-contain p-1" />
                    ) : (
                      <Icon name="lucide:package" class="w-8 h-8 text-gray-200" aria-hidden="true" />
                    )}
                  </div>
                  <div>
                    {rel.model && <p class="text-xs font-mono text-gray-400 mb-0.5">{rel.model}</p>}
                    <p class="font-bold text-gray-800 text-sm leading-snug group-hover:text-brand transition-colors">{rel.name}</p>
                    <p class="text-xs text-gray-500 mt-1 leading-relaxed line-clamp-2">{rel.shortDescription}</p>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>
  </div>

  <!-- ===== CONTACT CTA ===== -->
  <section class="bg-navy py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 md:flex items-center justify-between gap-8">
      <div class="mb-6 md:mb-0">
        <h2 class="text-2xl font-extrabold text-white mb-2">
          สนใจ {product.model ?? product.name}?
        </h2>
        <p class="text-blue-200 text-sm">
          ทีมวิศวกรพร้อมให้คำปรึกษาและเสนอราคา · {site.hours}
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a
          href={`/contact?model=${encodeURIComponent(product.model ?? product.name)}`}
          class="inline-flex items-center justify-center gap-2 bg-brand text-white font-bold px-7 py-3.5 rounded-lg hover:bg-brand/90 transition-colors"
        >
          <Icon name="lucide:send" class="w-4 h-4" aria-hidden="true" />
          ขอใบเสนอราคา
        </a>
        <a
          href={site.line}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-green-500 text-white font-bold px-7 py-3.5 rounded-lg hover:bg-green-400 transition-colors"
        >
          <Icon name="lucide:message-circle" class="w-4 h-4" aria-hidden="true" />
          LINE {site.lineId}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
