---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, titleEn, category, model, image, gallery, specs, price, pdf } = entry.data;

const categoryLabels: Record<string, string> = {
  'power-meter':   'เพาเวอร์มิเตอร์',
  'jumbo-display': 'จอแสดงผลขนาดใหญ่',
  'ntp-clock':     'นาฬิกา NTP',
  'haiwell':       'Haiwell PLC/HMI',
};

const categoryLabel = categoryLabels[category] ?? category;
---

<BaseLayout title={title} description={titleEn ? `${title} — ${titleEn} รุ่น ${model}` : `${title} รุ่น ${model} จาก LEOS METER`}>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2" aria-label="breadcrumb">
    <ol class="flex items-center gap-1 text-sm text-gray-500">
      <li><a href="/" class="hover:text-brand transition-colors">หน้าแรก</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li><a href="/products" class="hover:text-brand transition-colors">สินค้า</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li><a href={`/category/${category}`} class="hover:text-brand transition-colors">{categoryLabel}</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li class="text-gray-900 font-medium truncate">{model}</li>
    </ol>
  </nav>

  <!-- Main product layout -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Gallery -->
      <div class="space-y-4">
        <div class="aspect-[4/3] bg-gray-100 rounded-xl overflow-hidden">
          <Image
            src={image}
            alt={title}
            width={1200}
            height={900}
            class="w-full h-full object-cover"
          />
        </div>
        {gallery && gallery.length > 0 && (
          <div class="grid grid-cols-4 gap-2">
            {gallery.map((img, i) => (
              <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden">
                <Image
                  src={img}
                  alt={`${title} ภาพที่ ${i + 2}`}
                  width={300}
                  height={300}
                  class="w-full h-full object-cover"
                />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Product info -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <a
            href={`/category/${category}`}
            class="text-xs font-semibold text-brand bg-brand/10 px-2.5 py-1 rounded-full hover:bg-brand/20 transition-colors"
          >
            {categoryLabel}
          </a>
          <span class="text-xs text-gray-400 font-mono">{model}</span>
        </div>

        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 leading-tight mb-1">
          {title}
        </h1>
        {titleEn && (
          <p class="text-gray-500 text-sm mb-6">{titleEn}</p>
        )}

        <!-- Price -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6">
          <p class="text-xs text-gray-500 mb-1">ราคา</p>
          <p class="text-2xl font-extrabold text-brand">{price}</p>
          <p class="text-xs text-gray-400 mt-1">* ราคาไม่รวม VAT กรุณาสอบถามราคาพิเศษสำหรับการสั่งซื้อจำนวนมาก</p>
        </div>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a href="/contact" class="btn-primary flex-1 flex items-center justify-center gap-2 py-3">
            <Icon name="lucide:phone" class="w-4 h-4" aria-hidden="true" />
            ติดต่อสอบถาม
          </a>
          <a href="/contact" class="btn-outline flex-1 flex items-center justify-center gap-2 py-3">
            <Icon name="lucide:file-text" class="w-4 h-4" aria-hidden="true" />
            ขอใบเสนอราคา
          </a>
        </div>

        <!-- PDF download -->
        {pdf && (
          <a
            href={pdf}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-brand transition-colors mb-6"
          >
            <Icon name="lucide:download" class="w-4 h-4" aria-hidden="true" />
            ดาวน์โหลด Datasheet (PDF)
          </a>
        )}

        <!-- Specs table -->
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-3">ข้อมูลจำเพาะ</h2>
          <div class="border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full specs-table">
              <tbody>
                {specs.map((spec, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
                    <th scope="row">{spec.label}</th>
                    <td>{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Product description (markdown body) -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <h2 class="text-xl font-bold text-gray-900 mb-4">รายละเอียดสินค้า</h2>
      <div class="prose prose-gray max-w-3xl">
        <Content />
      </div>
    </div>

    <!-- Back link -->
    <div class="mt-10">
      <a href="/products" class="inline-flex items-center gap-2 text-brand font-semibold hover:underline text-sm">
        <Icon name="lucide:arrow-left" class="w-4 h-4" aria-hidden="true" />
        กลับสู่รายการสินค้า
      </a>
    </div>
  </div>
</BaseLayout>
