---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';
import { categoryGroups } from '../../data/categories';

const allSlugs = new Set(products.map((p) => p.category));
---

<BaseLayout
  title="สินค้าทั้งหมด — LEOS METER"
  description="รายการสินค้าอุปกรณ์วัดแสดงผลอุตสาหกรรม เพาเวอร์มิเตอร์ จอแสดงผล นาฬิกา NTP IoT Gateway Haiwell PLC/HMI จาก LEOS METER"
>
  <!-- Page header -->
  <section class="bg-gray-50 border-b border-gray-200 py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <p class="text-brand font-semibold text-sm uppercase tracking-wider mb-2">Products</p>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">สินค้าทั้งหมด</h1>
      <p class="text-gray-500 mt-2">อุปกรณ์วัดแสดงผลอุตสาหกรรม {products.length} รายการ</p>
    </div>
  </section>

  <!-- Category jump links -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-3 scrollbar-none" aria-label="หมวดหมู่สินค้า">
        {categoryGroups.map((group) => (
          <a
            href={`#${group.categories[0]?.slug ?? group.name}`}
            class="text-sm font-semibold text-gray-600 hover:text-brand px-3 py-1.5 rounded-lg hover:bg-gray-50 whitespace-nowrap transition-colors shrink-0"
          >
            {group.name}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Products by category group -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">
    {categoryGroups.map((group) => {
      const groupProducts = products.filter((p) =>
        group.categories.some((c) => c.slug === p.category || c.slug === p.subcategory)
      );
      if (groupProducts.length === 0) return null;
      return (
        <section id={group.categories[0]?.slug ?? group.name}>
          <div class="flex items-baseline justify-between mb-6">
            <div>
              <h2 class="text-xl md:text-2xl font-extrabold text-navy">{group.name}</h2>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
            {groupProducts.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
