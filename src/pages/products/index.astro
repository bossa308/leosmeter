---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');

const categoryMeta: Record<string, { name: string; nameEn: string }> = {
  'power-meter':   { name: 'เพาเวอร์มิเตอร์',       nameEn: 'Power Meters' },
  'jumbo-display': { name: 'จอแสดงผลขนาดใหญ่',       nameEn: 'Jumbo Displays' },
  'ntp-clock':     { name: 'นาฬิกา NTP',              nameEn: 'NTP Clocks' },
  'haiwell':       { name: 'Haiwell PLC/HMI',         nameEn: 'Haiwell PLC/HMI' },
} as const;

const categories = Object.keys(categoryMeta) as Array<keyof typeof categoryMeta>;

const grouped = categories.map((cat) => ({
  ...categoryMeta[cat],
  slug: cat,
  products: allProducts
    .filter((p) => p.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order),
}));
---

<BaseLayout
  title="สินค้าทั้งหมด"
  description="รายการสินค้าอุปกรณ์วัดแสดงผลอุตสาหกรรม เพาเวอร์มิเตอร์ จอแสดงผล นาฬิกา NTP Haiwell PLC/HMI จาก LEOS METER"
>
  <!-- Page header -->
  <section class="bg-gray-50 border-b border-gray-200 py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <p class="text-brand font-semibold text-sm uppercase tracking-wider mb-2">Products</p>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">สินค้าทั้งหมด</h1>
      <p class="text-gray-500 mt-2">อุปกรณ์วัดแสดงผลอุตสาหกรรมคุณภาพสูง {allProducts.length} รายการ</p>
    </div>
  </section>

  <!-- Category jump links -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-3 scrollbar-none" aria-label="หมวดหมู่สินค้า">
        {grouped.map((cat) => (
          <a
            href={`#${cat.slug}`}
            class="text-sm font-semibold text-gray-600 hover:text-brand px-3 py-1.5 rounded-lg hover:bg-gray-50 whitespace-nowrap transition-colors shrink-0"
          >
            {cat.name}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Products by category -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">
    {grouped.map((cat) => (
      <section id={cat.slug}>
        <div class="flex items-baseline justify-between mb-6">
          <div>
            <h2 class="section-heading">{cat.name}</h2>
            <p class="text-gray-500 text-sm mt-1">{cat.nameEn}</p>
          </div>
          <a
            href={`/category/${cat.slug}`}
            class="text-brand font-semibold text-sm hover:underline shrink-0"
          >
            ดูทั้งหมด →
          </a>
        </div>
        {cat.products.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {cat.products.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
        ) : (
          <p class="text-gray-400 py-8 text-center border border-dashed border-gray-200 rounded-xl">
            ยังไม่มีสินค้าในหมวดนี้
          </p>
        )}
      </section>
    ))}
  </div>
</BaseLayout>
