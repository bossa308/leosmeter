---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const posts = await getCollection('tutorial');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, description, pubDate, category, tags } = entry.data;
const dateStr = pubDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryLabel: Record<string, string> = {
  tutorial: 'บทความ',
  qa: 'Q&A',
  firmware: 'เฟิร์มแวร์',
  manual: 'คู่มือ',
};
---

<BaseLayout title={`${title} — LEOS METER`} description={description}>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2" aria-label="breadcrumb">
    <ol class="flex items-center gap-1 text-sm text-gray-500 flex-wrap">
      <li><a href="/" class="hover:text-brand transition-colors">หน้าแรก</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li><a href="/tutorial" class="hover:text-brand transition-colors">บทความ & คู่มือ</a></li>
      <li aria-hidden="true"><Icon name="lucide:chevron-right" class="w-4 h-4" /></li>
      <li class="text-gray-900 font-medium truncate">{title}</li>
    </ol>
  </nav>

  <!-- Article -->
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Meta -->
    <div class="flex items-center gap-2 mb-4 flex-wrap">
      <span class="text-xs font-semibold bg-brand/10 text-brand px-2.5 py-0.5 rounded-full">
        {categoryLabel[category] ?? category}
      </span>
      <span class="text-xs text-gray-400">{dateStr}</span>
    </div>

    <h1 class="text-2xl md:text-3xl font-extrabold text-navy leading-tight mb-3">{title}</h1>
    <p class="text-gray-500 text-lg mb-8">{description}</p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {tags.map((tag) => (
          <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-0.5 rounded-full">{tag}</span>
        ))}
      </div>
    )}

    <!-- MDX Content -->
    <div class="prose prose-gray max-w-none">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="/tutorial" class="inline-flex items-center gap-2 text-brand font-semibold hover:underline text-sm">
        <Icon name="lucide:arrow-left" class="w-4 h-4" aria-hidden="true" />
        กลับสู่บทความทั้งหมด
      </a>
    </div>
  </article>
</BaseLayout>
